            ]
        , rule ".err-msg"
            [ color (hex "f87171")
            , fontSize (rem 0.75)
            ]
        , rule ".card-time"
            [ color (hex "475569")
            , fontSize (rem 0.75)
            , property "margin-top" "0.5rem"
            ]
        , rule ".empty"
            [ color (hex "64748b")
            , textAlign "center"
            , padding (rem 3.0)
            ]
        ]
